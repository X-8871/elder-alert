# 网页面板登录配置，生产环境必须填写真实值
ELDER_DASHBOARD_USER=
ELDER_DASHBOARD_PASSWORD=

# HTTPS 生产环境保持 true；仅本地 HTTP 调试时设置为 false
ELDER_DASHBOARD_COOKIE_SECURE=true

# MiniMax TTS 配置，真实 Key 只写入服务器和本地忽略文件
ELDER_TTS_PROVIDER=minimax
ELDER_TTS_API_KEY=
ELDER_TTS_BASE_URL=https://api.minimaxi.com/v1
ELDER_TTS_MODEL=speech-2.8-hd
ELDER_TTS_VOICE=female-chengshu
ELDER_TTS_FORMAT=wav
ELDER_TTS_SAMPLE_RATE=16000
